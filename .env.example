# Google Gemini API Key (Optional fallback)
GEMINI_API_KEY=your_gemini_api_key_here

# ChatPDF API Key
# Jwenn sa nan https://www.chatpdf.com/api
CHATPDF_API_KEY=your_chatpdf_api_key_here

# ChatPDF Source ID
# Jwenn sa apre ou fin uploade PDF ou a nan ChatPDF
CHATPDF_SOURCE_ID=your_chatpdf_source_id_here
